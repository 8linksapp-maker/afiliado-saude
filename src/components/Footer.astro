---
const currentYear = new Date().getFullYear();

const quickLinks = [
  { href: '/', label: 'Home' },
  { href: '/blog', label: 'Blog' },
  { href: '/#sobre', label: 'Sobre' },
  { href: '/#contato', label: 'Contato' },
];

const categories = [
  { href: '/blog?cat=produtos-fisicos', label: 'Produtos Fisicos' },
  { href: '/blog?cat=produtos-digitais', label: 'Produtos Digitais' },
  { href: '/blog?cat=reviews', label: 'Reviews' },
  { href: '/blog?cat=comparativos', label: 'Comparativos' },
  { href: '/blog?cat=dicas', label: 'Dicas' },
];
---

<footer class="footer" id="contato">
  <div class="footer-top">
    <div class="container">
      <div class="footer-cta animate-on-scroll">
        <h2 class="footer-cta-title">
          Não perca nenhuma
          <span class="footer-cta-accent">recomendação</span>
        </h2>
        <p class="footer-cta-text">
          Acompanhe nosso blog para receber reviews honestos e dicas exclusivas.
        </p>
      </div>
    </div>
  </div>

  <div class="footer-main">
    <div class="container">
      <div class="footer-grid">
        <!-- Column 1: About -->
        <div class="footer-col footer-col-about">
          <a href="/" class="footer-logo">
            <span class="footer-logo-mark">S</span>
            <span class="footer-logo-text">SeuBlog</span>
          </a>
          <p class="footer-about">
            Reviews honestos e recomendações dos melhores produtos físicos e digitais
            do mercado. Ajudamos você a fazer escolhas inteligentes.
          </p>
          <div class="footer-social">
            <a href="#" class="footer-social-link" aria-label="Instagram">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <rect x="2" y="2" width="20" height="20" rx="5"/>
                <circle cx="12" cy="12" r="5"/>
                <circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" stroke="none"/>
              </svg>
            </a>
            <a href="#" class="footer-social-link" aria-label="YouTube">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19.1c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.25 29 29 0 0 0-.46-5.43z"/>
                <polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02" fill="currentColor" stroke="none"/>
              </svg>
            </a>
            <a href="#" class="footer-social-link" aria-label="Twitter / X">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M4 4l11.733 16h4.267l-11.733-16zM4 20l6.768-6.768M13.232 10.232L20 4"/>
              </svg>
            </a>
          </div>
        </div>

        <!-- Column 2: Quick Links -->
        <div class="footer-col">
          <h3 class="footer-heading">Navegação</h3>
          <ul class="footer-links">
            {quickLinks.map((link) => (
              <li>
                <a href={link.href} class="footer-link">{link.label}</a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Column 3: Categories -->
        <div class="footer-col">
          <h3 class="footer-heading">Categorias</h3>
          <ul class="footer-links">
            {categories.map((cat) => (
              <li>
                <a href={cat.href} class="footer-link">{cat.label}</a>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="container footer-bottom-inner">
      <p class="footer-copy">
        &copy; {currentYear} SeuBlog. Todos os direitos reservados.
      </p>
      <p class="footer-disclaimer">
        Este site contém links de afiliado. Ao comprar através dos nossos links,
        podemos receber uma comissão sem custo adicional para você.
      </p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: var(--color-bg-dark);
    color: #ccc;
  }

  /* CTA Section */
  .footer-top {
    padding: var(--space-4xl) 0;
    background: var(--color-primary);
    position: relative;
    overflow: hidden;
  }

  .footer-top::before {
    content: '';
    position: absolute;
    inset: 0;
    opacity: 0.05;
    background-image: radial-gradient(#fff 1px, transparent 1px);
    background-size: 24px 24px;
  }

  .footer-cta {
    text-align: center;
    position: relative;
    z-index: 1;
  }

  .footer-cta-title {
    font-family: var(--font-heading);
    font-size: var(--fs-3xl);
    font-weight: var(--fw-extrabold);
    color: #fff;
    margin-bottom: var(--space-md);
    letter-spacing: var(--ls-tight);
  }

  .footer-cta-accent {
    font-family: var(--font-display);
    font-weight: var(--fw-regular);
    font-style: italic;
    color: var(--color-primary-lighter);
  }

  .footer-cta-text {
    font-size: var(--fs-md);
    color: rgba(255, 255, 255, 0.75);
    max-width: 480px;
    margin: 0 auto;
    font-weight: var(--fw-light);
  }

  /* Main footer */
  .footer-main {
    padding: var(--space-4xl) 0 var(--space-3xl);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.8fr 1fr 1fr;
    gap: var(--space-4xl);
  }

  .footer-logo {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    text-decoration: none;
    margin-bottom: var(--space-xl);
  }

  .footer-logo:hover {
    color: #fff;
  }

  .footer-logo-mark {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    background: var(--color-primary-medium);
    color: #fff;
    font-family: var(--font-display);
    font-size: 1rem;
    font-style: italic;
    border-radius: var(--radius-sm);
  }

  .footer-logo-text {
    font-family: var(--font-heading);
    font-size: var(--fs-lg);
    font-weight: var(--fw-bold);
    color: #fff;
    letter-spacing: var(--ls-tight);
  }

  .footer-about {
    font-size: var(--fs-sm);
    line-height: var(--lh-relaxed);
    color: rgba(255, 255, 255, 0.4);
    margin-bottom: var(--space-xl);
    max-width: 340px;
    font-weight: var(--fw-light);
  }

  .footer-social {
    display: flex;
    gap: var(--space-sm);
  }

  .footer-social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: var(--radius-md);
    background: rgba(255, 255, 255, 0.05);
    color: rgba(255, 255, 255, 0.5);
    transition: all var(--transition-base);
    border: 1px solid rgba(255, 255, 255, 0.06);
  }

  .footer-social-link:hover {
    background: var(--color-primary-medium);
    color: #fff;
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(45, 106, 79, 0.3);
  }

  .footer-heading {
    font-size: var(--fs-xs);
    font-weight: var(--fw-semibold);
    color: rgba(255, 255, 255, 0.3);
    margin-bottom: var(--space-xl);
    text-transform: uppercase;
    letter-spacing: var(--ls-widest);
  }

  .footer-links {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .footer-link {
    font-size: var(--fs-sm);
    color: rgba(255, 255, 255, 0.55);
    transition: all var(--transition-fast);
    font-weight: var(--fw-light);
    display: inline-block;
  }

  .footer-link:hover {
    color: #fff;
    transform: translateX(4px);
  }

  /* Bottom bar */
  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    padding: var(--space-xl) 0;
  }

  .footer-bottom-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-xl);
  }

  .footer-copy {
    font-size: var(--fs-xs);
    color: rgba(255, 255, 255, 0.25);
  }

  .footer-disclaimer {
    font-size: var(--fs-xs);
    color: rgba(255, 255, 255, 0.2);
    max-width: 440px;
    text-align: right;
    line-height: var(--lh-normal);
  }

  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: var(--space-2xl);
    }

    .footer-bottom-inner {
      flex-direction: column;
      text-align: center;
    }

    .footer-disclaimer {
      text-align: center;
      max-width: 100%;
    }
  }
</style>
