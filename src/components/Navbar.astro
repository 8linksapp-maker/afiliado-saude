---
import { readData } from '../lib/readData';
import { getCollection } from 'astro:content';

const site = readData('siteConfig.json') || {};
const menu = readData('menu.json') || {};
const navLinks = (menu.items && menu.items.length > 0) ? menu.items : [
  { href: '/', label: 'Home' },
  { href: '/blog', label: 'Blog' },
  { href: '/sobre', label: 'Sobre' },
  { href: '/contato', label: 'Contato' },
];

const siteName = site.name || 'SeuBlog';
const siteLogo = site.logo || '';
const logoMark = (site.logoMark || siteName.charAt(0) || 'S').toUpperCase();
const logoSize = Math.max(20, Math.min(120, Number(site.logoSize) || 40));
const ctaText = site.ctaText || 'Explorar';
const ctaHref = site.ctaHref || '/blog';

const currentPath = Astro.url.pathname;

// menuHoverEnabled controla se o submenu abre passando o mouse (true) ou só ao clicar (false)
const menuHoverEnabled = site?.menuHoverEnabled !== false;

// Carrega categorias para itens com showCategories
const categoriesRaw = readData('categories.json', []) as any[];
function slugify(s: string) {
  return s.toString().toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g, '').replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
}
let allCategoryItems: { label: string; href: string }[] = [];
if (Array.isArray(categoriesRaw) && categoriesRaw.length > 0) {
  allCategoryItems = categoriesRaw.map((c: any) => {
    if (typeof c === 'string') return { label: c, href: `/categoria/${slugify(c)}` };
    return { label: c.name || c.label || '', href: `/categoria/${c.slug || slugify(c.name || c.label || '')}` };
  }).filter(c => c.label);
}
if (!allCategoryItems.length) {
  try {
    const posts = await getCollection('blog');
    const fromPosts = [...new Set(posts.map((p: any) => p.data.category).filter(Boolean))] as string[];
    allCategoryItems = fromPosts.map(c => ({ label: c, href: `/categoria/${slugify(c)}` }));
  } catch { /* sem coleção blog → ok */ }
}

function buildSubItems(item: any) {
  if (item.showCategories === true) return allCategoryItems;
  if (Array.isArray(item.children)) return item.children;
  return [];
}
---

<header class="navbar" id="navbar" data-menu-hover={menuHoverEnabled ? 'on' : 'off'}>
  <div class="container navbar-inner">
    <a href="/" class="navbar-logo">
      {siteLogo ? (
        <img src={siteLogo} alt={siteName} class="logo-image" style={`max-height: ${logoSize}px;`} />
      ) : (
        <>
          <span class="logo-mark">{logoMark}</span>
          <span class="logo-text">{siteName}</span>
        </>
      )}
    </a>

    <nav class="navbar-nav" id="navMenu">
      <ul class="navbar-links">
        {navLinks.map((link: any) => {
          const subs = buildSubItems(link);
          const hasSub = subs.length > 0;
          if (!hasSub) {
            return (
              <li>
                <a
                  href={link.href}
                  class:list={['navbar-link', { active: currentPath === link.href }]}
                >
                  {link.label}
                </a>
              </li>
            );
          }
          return (
            <li class="cms-dropdown">
              <a
                href={link.href}
                class:list={['navbar-link', 'cms-dropdown-trigger', { active: currentPath === link.href }]}
                data-cms-dropdown-trigger
              >
                {link.label}
                <span class="cms-dropdown-chevron" aria-hidden="true">▾</span>
              </a>
              <ul class="cms-dropdown-panel">
                {subs.map((s: any) => (
                  <li>
                    <a href={s.href} class="cms-dropdown-link">{s.label}</a>
                  </li>
                ))}
              </ul>
            </li>
          );
        })}
      </ul>
    </nav>

    <div class="navbar-actions">
      <a href={ctaHref} class="btn btn-primary btn-nav">{ctaText}</a>
      <button
        class="navbar-toggle"
        id="navToggle"
        aria-label="Abrir menu de navegação"
        aria-expanded="false"
      >
        <span class="hamburger"></span>
      </button>
    </div>
  </div>
</header>

<style>
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 1000;
    background-color: rgba(254, 252, 249, 0.92);
    backdrop-filter: blur(20px) saturate(1.8);
    -webkit-backdrop-filter: blur(20px) saturate(1.8);
    transition: all var(--transition-base);
  }

  .navbar.scrolled {
    box-shadow: 0 1px 0 var(--color-border-light), var(--shadow-sm);
  }

  .navbar-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: var(--navbar-height);
  }

  /* Logo */
  .navbar-logo {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    text-decoration: none;
    position: relative;
  }

  .navbar-logo:hover {
    color: var(--color-text);
  }

  .logo-mark {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    background: var(--color-primary);
    color: #fff;
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-style: italic;
    border-radius: var(--radius-md);
    transition: transform var(--transition-fast);
  }

  .navbar-logo:hover .logo-mark {
    transform: rotate(-4deg) scale(1.05);
  }

  .logo-text {
    font-family: var(--font-heading);
    font-size: var(--fs-lg);
    font-weight: var(--fw-bold);
    color: var(--color-text);
    letter-spacing: var(--ls-tight);
  }

  .logo-image {
    height: 36px;
    width: auto;
    display: block;
  }

  /* Nav links */
  .navbar-links {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
  }

  .navbar-link {
    font-size: var(--fs-sm);
    font-weight: var(--fw-medium);
    color: var(--color-text-secondary);
    padding: 0.5rem 1rem;
    border-radius: var(--radius-full);
    transition: all var(--transition-fast);
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
  }

  .navbar-link:hover {
    color: var(--color-primary);
    background: var(--color-primary-glow);
  }

  .navbar-link.active {
    color: var(--color-primary);
    font-weight: var(--fw-semibold);
    background: var(--color-primary-surface);
  }

  /* CMS dropdown — desktop */
  .cms-dropdown {
    position: relative;
  }

  .cms-dropdown-chevron {
    font-size: 0.7rem;
    transition: transform var(--transition-fast);
    line-height: 1;
  }

  .cms-dropdown-panel {
    position: absolute;
    top: 100%;
    left: 0;
    min-width: 240px;
    margin-top: 0.5rem;
    padding: 0.5rem;
    background: rgba(254, 252, 249, 0.98);
    backdrop-filter: blur(20px) saturate(1.8);
    -webkit-backdrop-filter: blur(20px) saturate(1.8);
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-lg, 14px);
    box-shadow: var(--shadow-lg, 0 12px 32px rgba(0, 0, 0, 0.12));
    list-style: none;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-6px);
    transition: opacity 0.2s ease, transform 0.2s ease, visibility 0.2s ease;
    z-index: 1001;
  }

  /* hover-on (default): abre passando o mouse */
  .navbar[data-menu-hover="on"] .cms-dropdown:hover > .cms-dropdown-panel,
  .navbar[data-menu-hover="on"] .cms-dropdown:focus-within > .cms-dropdown-panel {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }
  .navbar[data-menu-hover="on"] .cms-dropdown:hover > .navbar-link .cms-dropdown-chevron {
    transform: rotate(180deg);
  }

  /* Estado aberto via click — sempre visível em qualquer modo */
  .cms-dropdown.is-open > .cms-dropdown-panel {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }
  .cms-dropdown.is-open > .navbar-link .cms-dropdown-chevron {
    transform: rotate(180deg);
  }

  .cms-dropdown-link {
    display: block;
    padding: 0.5rem 0.75rem;
    border-radius: var(--radius-md);
    font-size: var(--fs-sm);
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: all var(--transition-fast);
  }
  .cms-dropdown-link:hover {
    color: var(--color-primary);
    background: var(--color-primary-glow);
  }

  /* CTA */
  .btn-nav {
    padding: 0.55rem 1.5rem;
    font-size: var(--fs-xs);
    border-radius: var(--radius-full);
  }

  .navbar-actions {
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }

  /* Hamburger */
  .navbar-toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: var(--space-sm);
    width: 40px;
    height: 40px;
    border-radius: var(--radius-md);
    transition: background var(--transition-fast);
  }

  .navbar-toggle:hover {
    background: var(--color-primary-glow);
  }

  .hamburger {
    display: block;
    width: 20px;
    height: 1.5px;
    background-color: var(--color-text);
    position: relative;
    transition: background-color var(--transition-fast);
    margin: 0 auto;
  }

  .hamburger::before,
  .hamburger::after {
    content: '';
    position: absolute;
    left: 0;
    width: 20px;
    height: 1.5px;
    background-color: var(--color-text);
    transition: transform var(--transition-base);
  }

  .hamburger::before { top: -6px; }
  .hamburger::after { top: 6px; }

  .navbar-toggle.active .hamburger {
    background-color: transparent;
  }

  .navbar-toggle.active .hamburger::before {
    transform: rotate(45deg) translate(4px, 4px);
  }

  .navbar-toggle.active .hamburger::after {
    transform: rotate(-45deg) translate(4px, -4px);
  }

  @media (max-width: 768px) {
    .navbar-toggle {
      display: flex;
      align-items: center;
    }

    .navbar-nav {
      position: fixed;
      top: var(--navbar-height);
      left: 0;
      width: 100%;
      background-color: rgba(254, 252, 249, 0.98);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border-bottom: 1px solid var(--color-border);
      padding: var(--space-lg);
      transform: translateY(-110%);
      opacity: 0;
      visibility: hidden;
      transition: all var(--transition-base);
      max-height: calc(100vh - var(--navbar-height));
      overflow-y: auto;
    }

    .navbar-nav.open {
      transform: translateY(0);
      opacity: 1;
      visibility: visible;
    }

    .navbar-links {
      flex-direction: column;
      gap: var(--space-xs);
      align-items: stretch;
    }

    .navbar-link {
      width: 100%;
      padding: 0.75rem 1rem;
      border-radius: var(--radius-md);
    }

    /* Dropdown no mobile: empilha inline (não absolute) */
    .cms-dropdown {
      width: 100%;
    }
    .cms-dropdown-panel {
      position: static;
      box-shadow: none;
      background: transparent;
      backdrop-filter: none;
      -webkit-backdrop-filter: none;
      border: none;
      padding: 0 0 0.5rem 1rem;
      margin: 0;
      opacity: 1;
      visibility: hidden;
      max-height: 0;
      overflow: hidden;
      transform: none;
      transition: max-height 0.25s ease, visibility 0s linear 0.25s;
    }
    /* hover não tem semântica em mobile; só click reage */
    .navbar[data-menu-hover="on"] .cms-dropdown:hover > .cms-dropdown-panel {
      visibility: hidden;
      max-height: 0;
      transition: max-height 0.25s ease, visibility 0s linear 0.25s;
    }
    .cms-dropdown.is-open > .cms-dropdown-panel {
      visibility: visible;
      max-height: 600px;
      transition: max-height 0.3s ease, visibility 0s linear 0s;
    }

    .navbar-actions .btn {
      display: none;
    }
  }
</style>

<script>
  const navbar = document.getElementById('navbar');
  const navToggle = document.getElementById('navToggle');
  const navMenu = document.getElementById('navMenu');

  window.addEventListener('scroll', () => {
    if (window.scrollY > 20) {
      navbar?.classList.add('scrolled');
    } else {
      navbar?.classList.remove('scrolled');
    }
  });

  navToggle?.addEventListener('click', () => {
    navToggle.classList.toggle('active');
    navMenu?.classList.toggle('open');
    const expanded = navToggle.getAttribute('aria-expanded') === 'true';
    navToggle.setAttribute('aria-expanded', String(!expanded));
  });

  // CMS dropdown — click toggle (acessibilidade + modo click-only + mobile)
  document.querySelectorAll<HTMLElement>('[data-cms-dropdown-trigger]').forEach(trigger => {
    trigger.addEventListener('click', (e) => {
      const drop = trigger.closest('.cms-dropdown') as HTMLElement | null;
      if (!drop) return;
      e.preventDefault();
      const wasOpen = drop.classList.contains('is-open');
      document.querySelectorAll('.cms-dropdown.is-open').forEach(d => d.classList.remove('is-open'));
      if (!wasOpen) drop.classList.add('is-open');
    });
  });
  document.addEventListener('click', (e) => {
    const t = e.target as HTMLElement;
    if (!t.closest('.cms-dropdown')) {
      document.querySelectorAll('.cms-dropdown.is-open').forEach(d => d.classList.remove('is-open'));
    }
  });
</script>
